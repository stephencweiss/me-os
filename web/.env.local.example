# =============================================================================
# Mode Configuration
# =============================================================================
# Set to "local" for CLI/MCP mode (uses Turso, no auth required)
# Leave unset for multi-tenant webapp mode (uses Supabase + Clerk)
# MEOS_MODE=local

# =============================================================================
# Clerk (required for web sign-in, API auth, and tenant Supabase JWT)
# =============================================================================
# Dashboard: https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
# Optional until you configure Clerk → Webhooks → `/api/webhooks/clerk` (user sync). Required in production if you rely on webhooks.
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret
# Routes must match the app (add NEXT_PUBLIC_BASE_PATH prefix when using subpath deploys)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# In Clerk Dashboard: enable Email (and optionally Username). Calendar uses “linked Google accounts”, not Clerk’s Google IdP, unless you choose otherwise.
#
# Supabase RLS expects JWT claim `app_user_id` (see supabase migrations for public.users RLS).
# Configure Clerk session claims or a JWT Template, then optionally set the template name:
# CLERK_SUPABASE_JWT_TEMPLATE=supabase

# =============================================================================
# Supabase Configuration (required for web mode)
# =============================================================================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# Optional: explicit ref for pnpm db:types (otherwise inferred from NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Required for database sessions in Middleware (Edge). If missing, Auth.js may fall back to JWT and break cookies (JWTSessionError / Invalid Compact JWE).
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Schema migrations from repo root: pnpm db:push (not used by Next.js at runtime)
# Create token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...

# NextAuth Configuration (legacy sessions / Auth.js adapter; Clerk is primary for web auth)
# Session signing secret — REQUIRED on Vercel/production (Auth.js MissingSecret if unset).
# Prefer AUTH_SECRET (Auth.js v5); NEXTAUTH_SECRET is an equivalent alias.
# Generate: openssl rand -base64 32
# AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Optional override for OAuth redirect_uri base (defaults to NEXTAUTH_URL). Must match Google Console "Authorized redirect URIs".
# AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
# Or set AUTH_SECRET to the same value instead of NEXTAUTH_SECRET.

# Subpath deployment (Hugo or another site reverse-proxies this app under a prefix).
# Omit for local dev at http://localhost:3000/. If set, must match Vercel rewrite destination path — see README "Web app: subpath".
# NEXT_PUBLIC_BASE_PATH=/app/me-os
# Then set AUTH_URL to the full public URL including that path, e.g. https://stephen-weiss.com/app/me-os

# Capacitor / native app — only if WebView origin ≠ API host (see below)
# When you load the app from http://localhost:3000 (or your dev URL), you can omit this.
# Set when: WKWebView shows capacitor://localhost (or similar) but API lives elsewhere — e.g. physical device using http://192.168.x.x:3000.
# Must match the origin you use in NEXTAUTH_URL / AUTH_URL (no trailing slash).
# NEXT_PUBLIC_APP_ORIGIN=http://192.168.1.10:3000
# Server + client custom URL scheme for OAuth return (bare name, no "://"). Keep both in sync.
# MOBILE_OAUTH_REDIRECT_SCHEME=meos
# NEXT_PUBLIC_MOBILE_OAUTH_REDIRECT_SCHEME=meos

# Google OAuth
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# OAuth consent must include Calendar (read-only): scope is set in lib/auth.config.ts
# Authorized redirect URIs must include:
#   - {AUTH_URL or NEXTAUTH_URL origin + path}/api/auth/callback/google  (legacy NextAuth web, if used)
#   - {same base}/api/auth/mobile/google/callback  (Capacitor)
#   - {same base}/api/google/link/callback  (Clerk web: Connect Google Calendar)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token Encryption (for storing Google OAuth tokens in linked_google_accounts)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# After changing Calendar scopes, users should sign out and sign in again (Google refresh token).
# Schema: from repo root run `pnpm db:push` (see scripts/migrations/README.md).

# Anthropic API (for AI features)
ANTHROPIC_API_KEY=sk-ant-...your-api-key

# =============================================================================
# Turso Configuration (required for local mode only)
# =============================================================================
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
