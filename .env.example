# =============================================================================
# MeOS Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For the Next.js app, copy web/.env.local.example → web/.env.local (canonical list for web).
#
# Not all variables are required - it depends on which mode you're running:
# - CLI/MCP Mode: Uses file-based Google OAuth tokens
# - Webapp Mode: Supabase + Clerk (sign-in); Google Calendar uses linked-account OAuth (see web/.env.local.example)
# =============================================================================

# -----------------------------------------------------------------------------
# Mode Selection
# -----------------------------------------------------------------------------
# Set to "local" to run in CLI/MCP mode without auth
# Leave unset or set to "web" for multi-tenant webapp mode
MEOS_MODE=local

# -----------------------------------------------------------------------------
# Google OAuth (CLI/MCP Mode)
# -----------------------------------------------------------------------------
# Used by lib/google-auth.ts for file-based token storage
# Get credentials from: https://console.cloud.google.com/apis/credentials
#
# Default account when multiple are configured (personal, work, etc.)
GOOGLE_ACCOUNT=personal

# Directory for storing OAuth credentials and tokens
# Default: ./config
GOOGLE_CREDENTIALS_DIR=./config

# -----------------------------------------------------------------------------
# Turso Database (CLI/MCP Mode - Optional)
# -----------------------------------------------------------------------------
# Local SQLite database via Turso for CLI mode
# Get from: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# -----------------------------------------------------------------------------
# Supabase (Webapp Mode)
# -----------------------------------------------------------------------------
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Public keys (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# -----------------------------------------------------------------------------
# Clerk (Webapp Mode — primary auth for the Next.js app)
# -----------------------------------------------------------------------------
# Full reference: web/.env.local.example (use that file for local web development).
# Dashboard: https://dashboard.clerk.com/ → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
# Optional until webhooks are configured (user sync → /api/webhooks/clerk)
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret
# Optional: named JWT template slug if Supabase RLS uses a custom Clerk template
# CLERK_SUPABASE_JWT_TEMPLATE=supabase
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# OAuth deployment URL (Webapp — Google Calendar “Connect” flow, not NextAuth)
# -----------------------------------------------------------------------------
# Public origin of the Next app; required for `/api/google/link/*` redirect_uri.
# Use AUTH_URL or NEXTAUTH_URL (either name is read by the app).
NEXTAUTH_URL=http://localhost:3000
# State cookie signing for Google link OAuth: AUTH_SECRET, NEXTAUTH_SECRET, or CLERK_SECRET_KEY
AUTH_SECRET=your-auth-secret-here
# Base URL for client-side API calls when the WebView origin differs (e.g. Capacitor).
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Google OAuth (Calendar API — linked accounts)
# Same credentials can be used as CLI, but with webapp redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Token Encryption (Webapp Mode)
# -----------------------------------------------------------------------------
# For encrypting stored Google OAuth tokens in the database
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-character-hex-key

# -----------------------------------------------------------------------------
# Anthropic API (AI Features - Optional)
# -----------------------------------------------------------------------------
# Required for /api/ai/* endpoints
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-api-key

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
NODE_ENV=development
