# =============================================================================
# MeOS Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For webapp, also copy web/.env.local.example to web/.env.local
#
# Not all variables are required - it depends on which mode you're running:
# - CLI/MCP Mode: Uses file-based Google OAuth tokens
# - Webapp Mode: Uses Supabase + NextAuth for multi-tenant auth
# =============================================================================

# -----------------------------------------------------------------------------
# Mode Selection
# -----------------------------------------------------------------------------
# Set to "local" to run in CLI/MCP mode without auth
# Leave unset or set to "web" for multi-tenant webapp mode
MEOS_MODE=local

# -----------------------------------------------------------------------------
# Google OAuth (CLI/MCP Mode)
# -----------------------------------------------------------------------------
# Used by lib/google-auth.ts for file-based token storage
# Get credentials from: https://console.cloud.google.com/apis/credentials
#
# Default account when multiple are configured (personal, work, etc.)
GOOGLE_ACCOUNT=personal

# Directory for storing OAuth credentials and tokens
# Default: ./config
GOOGLE_CREDENTIALS_DIR=./config

# -----------------------------------------------------------------------------
# Turso Database (CLI/MCP Mode - Optional)
# -----------------------------------------------------------------------------
# Local SQLite database via Turso for CLI mode
# Get from: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# -----------------------------------------------------------------------------
# Supabase (Webapp Mode)
# -----------------------------------------------------------------------------
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Public keys (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# -----------------------------------------------------------------------------
# NextAuth (Webapp Mode)
# -----------------------------------------------------------------------------
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-nextauth-secret-here
AUTH_SECRET=your-nextauth-secret-here
# Base URL of the Next.js app for client-side API calls (no trailing slash).
# In the browser, omit this: the app uses window.location.origin.
# In Capacitor (native), the WebView origin is often capacitor://…, not your dev
# server—set this to the Next app’s public base URL (same scheme/host/port as the server
# that serves /api and auth; often matches NEXTAUTH_URL). Example on a device:
# http://192.168.x.x:3000 so Google sign-in can POST to /api/auth/mobile/*.
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Google OAuth for webapp login
# Same credentials can be used as CLI, but with webapp redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Token Encryption (Webapp Mode)
# -----------------------------------------------------------------------------
# For encrypting stored Google OAuth tokens in the database
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-character-hex-key

# -----------------------------------------------------------------------------
# Anthropic API (AI Features - Optional)
# -----------------------------------------------------------------------------
# Required for /api/ai/* endpoints
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-api-key

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
NODE_ENV=development
